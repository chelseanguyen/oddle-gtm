        "jsCode": "const preparedData = $('Prepare Company Search').item.json;\n\nlet companyFound = null;\nlet foundByMethod = null;\n\nconst searchNodes = [\n  { name: 'websiteDomain', node: 'Search Company by Website Domain' },\n  { name: 'emailDomain', node: 'Search Company by Email Domain' },\n  { name: 'instagram', node: 'Search Company by Instagram' },\n  { name: 'placeId', node: 'Search Company by PlaceId' },\n  { name: 'placeName', node: 'Search Company by PlaceName' }\n];\n\nfor (const search of searchNodes) {\n  try {\n    const result = $(search.node).item.json;\n    if (result?.data?.length > 0) {\n      companyFound = result.data[0];\n      foundByMethod = search.name;\n      break;\n    }\n  } catch (e) {}\n}\n\nreturn [{\n  json: {\n    companyFound: !!companyFound,\n    companyRecordId: companyFound?.id?.record_id || '',\n    foundByMethod,\n    needsInstagramUpdate: companyFound && foundByMethod !== 'instagram' && preparedData.instagramHandle,\n    ...preparedData\n  }\n}];"
