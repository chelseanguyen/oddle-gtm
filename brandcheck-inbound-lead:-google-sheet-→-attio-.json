    {
      "parameters": {},
      "id": "merge-company-paths-001",
      "name": "Merge Company Search Paths",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [
        3120,
        192
      ]
    },
    {
      "parameters": {
        "jsCode": "const deduplicateData = $('Deduplicate Check').item.json;\nconst website = deduplicateData.website || '';\nconst email = deduplicateData.email || '';\nconst instagramHandle = deduplicateData.instagramHandle || '';\nconst placeId = deduplicateData.placeId || '';\nconst placeName = deduplicateData.placeName || '';\n\nfunction extractDomain(url) {\n  if (!url) return '';\n  try {\n    let domain = url.replace(/^https?:\\/\\//, '').replace(/^www\\./, '');\n    domain = domain.split('/')[0].toLowerCase();\n    return domain;\n  } catch (e) { return ''; }\n}\n\nfunction extractEmailDomain(email) {\n  if (!email || !email.includes('@')) return '';\n  return email.split('@')[1].toLowerCase();\n}\n\n// Website domain blacklist (social/booking platforms)\nconst websiteBlacklist = ['facebook.com', 'instagram.com', 'chope.co', 'quandoo.com', 'fb.com', 'm.facebook.com', 'chope.com.sg'];\n\n// Email domain blacklist (social/booking + B2C email providers)\nconst emailBlacklist = [\n  // Social/booking platforms\n  'facebook.com', 'instagram.com',\n  // B2C email providers\n  'gmail.com', 'yahoo.com', 'outlook.com', 'hotmail.com', 'live.com', 'msn.com',\n  'icloud.com', 'me.com', 'mac.com', 'aol.com', 'protonmail.com', 'proton.me',\n  'ymail.com', 'rocketmail.com', 'mail.com', 'zoho.com', 'gmx.com', 'gmx.net'\n];\n\nfunction isWebsiteBlacklisted(domain) {\n  if (!domain) return true;\n  return websiteBlacklist.some(bl => domain === bl || domain.endsWith('.' + bl));\n}\n\nfunction isEmailBlacklisted(domain) {\n  if (!domain) return true;\n  return emailBlacklist.some(bl => domain === bl || domain.endsWith('.' + bl));\n}\n\nconst websiteDomain = extractDomain(website);\nconst emailDomain = extractEmailDomain(email);\n\nlet personRecordId = '';\nconst listEntry = $json;\nif (listEntry?.data?.parent_record_id) {\n  personRecordId = listEntry.data.parent_record_id;\n}\n\nreturn [{\n  json: {\n    websiteDomain: isWebsiteBlacklisted(websiteDomain) ? '' : websiteDomain,\n    emailDomain: isEmailBlacklisted(emailDomain) ? '' : emailDomain,\n    instagramHandle: instagramHandle.replace('@', ''),\n    placeId,\n    placeName,\n    country: deduplicateData.country || '',\n    cuisine: deduplicateData.cuisine || '',\n    personRecordId\n  }\n}];"
      },
      "id": "prepare-company-search-001",
