    {
      "parameters": {
        "jsCode": "const allRows = $input.all();\nconst triggerData = $('New Record Created').item.json;\nconst currentPhoneNumber = String(triggerData.phoneNumber || '');\n\nconst matchCount = allRows.filter(item => String(item.json.phoneNumber || '') === currentPhoneNumber).length;\nconst isDuplicate = matchCount > 1;\n\n// Convert timestamp to ISO 8601 date format (YYYY-MM-DD)\nconst rawTimestamp = triggerData.timestamp || '';\nlet dateOnly = '';\nif (rawTimestamp) {\n  // Extract just the date part (YYYY-MM-DD)\n  const parts = rawTimestamp.match(/^(\\d{4}-\\d{2}-\\d{2})/);\n  if (parts) {\n    dateOnly = parts[1];\n  }\n}\n\nreturn [{\n  json: {\n    isDuplicate,\n    placeName: triggerData.placeName || '',\n    placeId: triggerData.placeId || '',\n    phoneNumber: currentPhoneNumber,\n    email: (triggerData.email || '').trim(),\n    instagramHandle: triggerData.instagramHandle || '',\n    overallScore: triggerData.overallScore || '',\n    role: triggerData.role || '',\n    country: triggerData.country || '',\n    website: triggerData.website || '',\n    cuisine: triggerData.cuisine || '',\n    signatureDishes: triggerData.signatureDishes || '',\n    timestamp: dateOnly,\n    pdfLink: triggerData.pdfLink || ''\n  }\n}];"
      },
